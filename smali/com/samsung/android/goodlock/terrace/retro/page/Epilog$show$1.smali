    const-string v1, "\nGOODLOCK 1994\n\n1994\ub144\uc5d0 \ubcf8 \uad7f\ub77d\uc740 \uc774\ub7f0 \ubaa8\uc2b5\uc774\uc5c8\uc744\uae4c\n\n\n\uaf30\ub300\ub294 \uc2eb\uc9c0\ub9cc \'\ub808\ud2b8\ub85c \uac10\uc131\'\uc5d0\ub294 \ud479 \ube60\uc9c4 \uc80a\uc740\uc774\ub4e4\n\uc774\uc820 \ub274\ud2b8\ub85c, \ud799\ud2b8\ub85c, \ube48\ud2b8\ub85c \ub4f1 \uc0c8\ub85c\uc6b4 \ud750\ub984\uc73c\ub85c\n\uc9c4\ud654 \uc911\n\n\ud754\ud788 \u2018\uaf30\ub300\u2019\ub77c\ub294 \ub9d0\uc740 \uad8c\uc704\uc801\uc778 \uc0ac\uace0\ub97c \uac00\uc9c4 \uc5b4\ub978\n\uc744 \ube44\ud558\ud558\ub294 \ud559\uc0dd\ub4e4\uc758 \uc740\uc5b4\ub2e4. \n\ucd5c\uadfc\uc5d0\ub294 \uaf30\ub300\uc9c8\ud558\ub294 \uc0ac\ub78c\uc744 \uc758\ubbf8\ud558\uae30\ub3c4 \ud55c\ub2e4.\n\uc80a\uc740\uc774\ub4e4\uc740 \uaf30\ub300\uc5d0\ub294 \ubc18\uac10\uc744 \uac00\uc9c0\uc9c0\ub9cc \u201c\ub77c\ub5bc\ub294 \ub9d0\uc774\n\uc57c~\u201d\ub77c\ub294 \uc5b4\ub974\uc2e0\ub4e4\uc758 \ud45c\ud604\uc5d0\ub294 \uc990\uac70\uc6cc\ud558\uae30\ub3c4 \ud55c\ub2e4. \n\uc80a\uc740\uc774\ub4e4 \uc0ac\uc774\uc5d0\uc11c\ub3c4 \uacfc\uac70 \uc811\ud574\ubcf4\uc9c0 \ubabb\ud55c \uadf8 \uc2dc\uc808\uc774\n\ub354 \uc774\uc0c1 \uadf8\uc800 \u2018\uc61b\ub0a0\u2019\uc774 \uc544\ub2cc \u2018\ub808\ud2b8\ub85c \uac10\uc131\u2019\uc73c\ub85c\n\ub5a0\uc624\ub974\uace0 \uc788\ub2e4. \n\n\ucf54\ub85c\ub09819\uac00 \uc7a5\uae30\ud654\ub418\uba74\uc11c \uacfc\uac70 \ud3c9\ubc94\ud588\ub358 \uc77c\uc0c1\uc774 \ub354\uc6b1 \n\uadf8\ub9ac\uc6cc\uc9c0\uc790, \uacfc\uac70 \uadf8 \uc2dc\uc808\ub85c \ub3cc\uc544\uac00\ub824\ub294 \ub808\ud2b8\ub85c \uac10\uc131\n\uc740 \ud558\ub098\uc758 \ud2b8\ub80c\ub4dc\ub85c\uc368 \uc790\ub9ac \uc7a1\uc558\ub2e4.\n\n\ub274\ud2b8\ub85c\ub294 \ub808\ud2b8\ub85c(Re-tro)\uc640 \ube44\uc2b7\ud55c \ub4ef\ud558\uc9c0\ub9cc \ub2e4\ub974\ub2e4.\n\ub808\ud2b8\ub85c\ub294 30~50\ub300\uac00 \uacfc\uac70\uc5d0 \ub300\ud55c \uadf8\ub9ac\uc6c0\uc73c\ub85c \ubcf5\uace0\uc5d0\n\ube60\uc838\ub4dc\ub294 \ud604\uc0c1\uc774\ub2e4. \uacfc\uac70\ub97c \ub2e8\uc21c\ud558\uac8c \uc7ac\ud604\ud55c \uac83\uc774 \ub808\n\ud2b8\ub85c\ub77c\uba74 \ub274\ud2b8\ub85c\ub294 \ud55c \ub2e8\uacc4 \uc9c4\ud654\ud574 \uacfc\uac70\uc758 \ud5a5\uc218\ub97c \ud604\n\uc7ac\uc758 \uac10\uc131\uc5d0 \ub9de\uac8c \uc7ac\ud574\uc11d\ud558\ub294 \uac83\uc744 \uc758\ubbf8\ud55c\ub2e4.\n\n\uc774\uc81c \ub808\ud2b8\ub85c\ub294 \uacfc\uac70\ub97c \ucd94\uc5b5\ud558\uae30\ub9cc \ud558\ub294 \uc7a5\uce58\uac00 \uc544\ub2c8\ub2e4.\n\uc0c8\ub85c\uc6b4 \ud2b8\ub80c\ub4dc\uc640 \ubb38\ud654\ub85c \ub300\ub450\ud558\uace0 \uc788\ub2e4. \ud604\ub300\ub85c \uc18c\ud658\n\ub41c \uacfc\uac70\ub294 \uc775\uc219\ud568\uc774 \uc8fc\ub294 \uc548\uc815\uac10\ubfd0\ub9cc \uc544\ub2c8\ub77c \uc0c8\ub85c\uc6b4 \uc2e0\n\uc120\ud568\uae4c\uc9c0 \uc8fc\uace0 \uc788\ub2e4.\n\n\ub808\ud2b8\ub85c\ub294 \uacfc\uac70\uc758 \uc591\uc0c1\uc73c\ub85c\ub9cc \ub0a8\uc9c0 \uc54a\uace0 2000\ub144\ub300\uc5d0 \ub9de\n\ucd98 \uc7ac\ud574\uc11d \ub41c \ub274\ud2b8\ub85c\ub85c \ud0c8\ubc14\uafc8\ud588\ub2e4. \uacfc\uac70\ub97c \ucd94\uc5b5\ud558\ub294\n\uac83\uc744 \ub118\uc5b4 \uc0c8\ub85c\uc6b4 \u2018\ub300\uc138\u2019\ub85c \uc790\ub9ac\ub9e4\uae40\ud55c \uac83\uc774\ub2e4.\n\n\uc2dc\uac04\uc758 \uac04\uadf9\uc744 \ub118\uc5b4 \uc18c\ud658\ub41c \uacfc\uac70\uc758 \ud5a5\uae30\ub294 \uc9c0\uae08\ub3c4\n\uc0c8\ub86d\uac8c \ud0c4\uc0dd\ud558\uace0 \uc788\ub2e4.\n\nFramework \ud5e4\ucee4\ud1a4 \ub808\ud2b8\ub85cUI \ud300 \uacfc\uc81c \uc18c\uac1c\uc5d0\uc11c \ubc1c\ucdcc\ud568. \n"

    invoke-virtual {v0, v1, p1}, Lcom/samsung/android/goodlock/terrace/retro/RetroUtil;->addContent(Ljava/lang/CharSequence;Lcom/samsung/android/goodlock/terrace/retro/ChainJob$ThisJob;)V

